{
    "data": {
        "train_dir": "./data/train",
        "val_dir": "./data/val",
        "mode": "paired",
        "sample_rate": 8000,
        "segment_length": 32000,
        "snr_range": [-5, 20],
        "augment": true
    },
    "training": {
        "batch_size": 8,
        "num_workers": 4,
        "epochs": 100,
        "save_interval": 5,
        "val_interval": 1,
        "log_interval": 50,
        "seed": 42
    },
    "optimizer": {
        "type": "AdamW",
        "lr": 1e-3,
        "weight_decay": 1e-2,
        "betas": [0.9, 0.999]
    },
    "scheduler": {
        "type": "cosine",
        "warmup_epochs": 5,
        "min_lr": 1e-6
    },
    "loss": {
        "l1_weight": 1.0,
        "l2_weight": 1.0,
        "stft_weight": 1.0,
        "fft_sizes": [512, 1024, 256],
        "hop_sizes": [128, 256, 64],
        "win_sizes": [512, 1024, 256]
    },
    "checkpoint": {
        "resume": null,
        "pretrained": "pytorch_model.bin",
        "save_dir": "./checkpoints"
    },
    "distributed": {
        "enabled": false
    },
    "tensorboard": {
        "log_dir": "./runs"
    }
}
